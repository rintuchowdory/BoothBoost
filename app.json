{
  "expo": {
    "name": "BoothBoost",
    "slug": "boothboost",
    "scheme": "boothboost",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0D0E11"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rintuchowdory.boothboost"
    },
    "android": {
      "package": "com.rintuchowdory.boothboost",
      "adaptiveIcon": {
        "backgroundColor": "#0D0E11"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-sharing"
    ],
    "extra": {
      "router": {}
    }
  }
}
